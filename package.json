{
  "name": "steam-discord-reporter",
  "version": "1.0.0",
  "description": "Cloudflare Worker automation that reports Steam wishlist and sales activity to Discord without exposing revenue.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KBT-0/steam-discord-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/KBT-0/steam-discord-reporter/issues"
  },
  "homepage": "https://github.com/KBT-0/steam-discord-reporter#readme",
  "keywords": [
    "steamworks",
    "discord",
    "cloudflare-workers",
    "wrangler",
    "automation"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260531.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.18.0"
  }
}
